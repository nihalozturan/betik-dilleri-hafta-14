<h1>JavaScript Functions</h1>
<h2>The setTimeout() Method</h2>

<p>Wait 3 seconds (3000 milliseconds) for this page to change.</p>

<h2 id="demo"></h2>

<script>
setTimeout(myFunction, 3000);


function myFunction() {
const deneme = ['Nihal','Nergis','Melek','Batur'];
for (let i = 0; i < deneme.length; i++){

	document.getElementById("demo").innerHTML = "I love You "+ [deneme];
    }
    }
</script>

